      { "label": "Creative / Arts", "effects": { "industryMatch": "creative", "multipliers": { "jobMarket": 1.3, "culturalOfferings": 1.3 } } },
      { "label": "Media / Journalism", "effects": { "industryMatch": "media", "multipliers": { "jobMarket": 1.4, "languageAccess": 1.3, "pressFreedom": 1.3 } } },
      { "label": "Startup / Entrepreneurship", "effects": { "industryMatch": "startup", "multipliers": { "jobMarket": 1.4, "internetQuality": 1.3, "economicOutlook": 1.3 } } },
      { "label": "Trade / Logistics", "effects": { "industryMatch": "trade", "multipliers": { "jobMarket": 1.4, "transitQuality": 1.3, "economicOutlook": 1.2 } } },
      { "label": "Tourism & Hospitality", "effects": { "industryMatch": "tourism", "multipliers": { "jobMarket": 1.3, "foodScene": 1.2, "culturalOfferings": 1.2 } } },
      { "label": "Fashion / Luxury", "effects": { "industryMatch": "fashion", "multipliers": { "jobMarket": 1.4, "culturalOfferings": 1.3 } } },
      { "label": "Film & Entertainment", "effects": { "industryMatch": "film", "multipliers": { "jobMarket": 1.4, "culturalOfferings": 1.3, "nightlife": 1.2 } } },
      { "label": "Healthcare / Medicine", "effects": { "multipliers": { "healthcareQuality": 1.5, "safety": 1.3, "jobMarket": 1.3 } } },
      { "label": "Education / Academia", "effects": { "multipliers": { "educationQuality": 1.5, "culturalOfferings": 1.2, "jobMarket": 1.2 } } },
      { "label": "Government / Policy", "effects": { "multipliers": { "govProgressiveness": 1.2, "corruption": 1.3, "jobMarket": 1.2 } } },
      { "label": "Energy / Mining", "effects": { "industryMatch": "energy", "multipliers": { "jobMarket": 1.4, "economicOutlook": 1.2 } } },
      { "label": "Not applicable", "effects": {} }

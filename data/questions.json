[
  {
    "id": "climate",
    "text": "What climate type do you prefer?",
    "type": "single",
    "modes": ["living", "visiting"],
    "options": [
      { "label": "Warm year-round — tropical or subtropical", "effects": { "climateMatch": "tropical,subtropical" } },
      { "label": "Four distinct seasons — real summers and winters", "effects": { "climateMatch": "continental" } },
      { "label": "Cool and mild — no extreme heat or cold", "effects": { "climateMatch": "temperate" } },
      { "label": "Hot and dry — desert or arid", "effects": { "climateMatch": "desert" } },
      { "label": "No preference", "effects": {} }
    ]
  },
  {
    "id": "climateDetails",
    "text": "Any specific climate preferences? (pick all that apply)",
    "type": "multi",
    "maxSelect": 4,
    "modes": ["living", "visiting"],
    "options": [
      { "label": "Lots of sunshine is essential", "effects": { "multipliers": { "sunshine": 1.5 } } },
      { "label": "Prefer dry — rain bothers me", "effects": { "inversions": ["rainfall"], "multipliers": { "rainfall": 1.5 } } },
      { "label": "Love heat and humidity", "effects": { "multipliers": { "humidity": 1.3, "winterWarmth": 1.5 } } },
      { "label": "Warm but dry is ideal", "effects": { "inversions": ["humidity"], "multipliers": { "humidity": 1.3, "winterWarmth": 1.3 } } },
      { "label": "Prefer cool temperatures — heat bothers me", "effects": { "inversions": ["humidity", "winterWarmth"], "multipliers": { "winterWarmth": 1.3 } } },
      { "label": "I love snow and cold winters", "effects": { "inversions": ["winterWarmth"], "multipliers": { "winterWarmth": 1.5 } } },
      { "label": "I prefer overcast or grey skies", "effects": { "inversions": ["sunshine"], "multipliers": { "sunshine": 1.3 } } },
      { "label": "No specific preferences", "effects": { "multipliers": { "sunshine": 0.2, "humidity": 0.2, "rainfall": 0.2, "winterWarmth": 0.2 } } }
    ]
  },
  {
    "id": "lifeStage",
    "text": "Who are you planning to live with?",
    "type": "single",
    "modes": ["living"],
    "options": [
      { "label": "Just me — flying solo", "effects": { "multipliers": { "nightlife": 1.2, "costOfLiving": 1.1 } } },
      { "label": "Partner or spouse — no kids", "effects": { "multipliers": { "safety": 1.1, "affordability": 1.1 } } },
      { "label": "Family with young children", "effects": { "multipliers": { "educationQuality": 1.8, "safety": 1.5, "healthcareQuality": 1.4, "affordability": 1.3, "airQuality": 1.3, "nightlife": 0.4 } } },
      { "label": "Family with teenagers", "effects": { "multipliers": { "educationQuality": 1.5, "safety": 1.3, "culturalOfferings": 1.2, "affordability": 1.2 } } },
      { "label": "Retiring abroad", "effects": { "multipliers": { "healthcareQuality": 1.8, "safety": 1.4, "airQuality": 1.3, "walkability": 1.3, "costOfLiving": 1.3, "jobMarket": 0.1, "nightlife": 0.4 } } },
      { "label": "Student", "effects": { "multipliers": { "educationQuality": 1.5, "costOfLiving": 1.4, "nightlife": 1.2, "jobMarket": 0.3 } } }
    ]
  },
  {
    "id": "citySize",
    "text": "What scale of city suits you?",
    "type": "single",
    "modes": ["living", "visiting"],
    "options": [
      { "label": "Megacity (5M+) — I love the energy and scale", "effects": { "populationFilter": { "min": 3000000, "factor": 0.8 } } },
      { "label": "Large city (500k–5M) — urban but navigable", "effects": { "populationFilter": { "min": 400000, "max": 6000000, "factor": 0.8 } } },
      { "label": "Mid-size or smaller — more human scale", "effects": { "populationFilter": { "max": 2500000, "factor": 0.8 }, "multipliers": { "affordability": 1.1 } } },
      { "label": "No preference", "effects": {} }
    ]
  },
  {
    "id": "workStyle",
    "text": "How do you work?",
    "type": "single",
    "modes": ["living"],
    "options": [
      { "label": "Fully remote — I can work from anywhere", "effects": { "multipliers": { "internetQuality": 1.5, "costOfLiving": 1.3, "jobMarket": 0.2 } } },
      { "label": "Hybrid — split between home and office", "effects": { "multipliers": { "transitQuality": 1.2, "jobMarket": 1.1 } } },
      { "label": "On-site — I need a strong local job market", "effects": { "multipliers": { "jobMarket": 1.5, "transitQuality": 1.2 } } },
      { "label": "Student or not currently working", "effects": { "multipliers": { "costOfLiving": 1.3, "jobMarket": 0.2 } } },
      { "label": "Retired", "effects": { "multipliers": { "jobMarket": 0.1 } } }
    ]
  },
  {
